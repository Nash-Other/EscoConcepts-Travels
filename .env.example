# Required for database connection
DATABASE_URL=postgresql://user:password@host:port/database

# JWT secret (generate a strong random string)
JWT_SECRET=your-very-long-random-secret-here

# App URL (used for password reset links)
APP_URL=https://your-app.onrender.com

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=onboarding@resend.dev

# Admin bootstrap (only used if admin user does not exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongAdminPass123
ADMIN_FIRST_NAME=Esco
ADMIN_LAST_NAME=Admin

# Optional: restrict CORS origins (comma-separated)
CORS_ORIGIN=https://your-app.onrender.com

# Secret for the cron endpoint (use a random string)
CRON_SECRET=your-cron-secret

# Optional: send contact form notifications to this email
CONTACT_NOTIFICATION_EMAIL=hello@escoconceptstravels.com

# Node environment (production or development)
NODE_ENV=production

# Cloudflare R2 Storage (Blog Images)
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=escoconcepts-travels
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev